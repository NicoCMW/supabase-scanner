{
  "name": "supascanner",
  "version": "1.0.0",
  "description": "CLI tool for scanning Supabase projects for security vulnerabilities. Checks RLS policies, storage buckets, and auth configuration.",
  "type": "module",
  "bin": {
    "supascanner": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@supascanner/core": "^1.0.0",
    "commander": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "keywords": [
    "supabase",
    "security",
    "scanner",
    "rls",
    "cli",
    "audit",
    "row-level-security",
    "storage",
    "auth"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/NicoCMW/supabase-scanner.git",
    "directory": "packages/cli"
  },
  "homepage": "https://supabase-scanner.vercel.app",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
