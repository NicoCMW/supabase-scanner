NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (all optional -- if absent, billing degrades to waitlist/email capture)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Google Tag Manager
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Email (Resend)
RESEND_API_KEY=re_...
EMAIL_FROM=SupaScanner <noreply@supascanner.com>
NEXT_PUBLIC_SITE_URL=http://localhost:3000
CRON_SECRET=your-cron-secret

# Cloudflare Turnstile (CAPTCHA)
# Get keys from https://dash.cloudflare.com → Turnstile
# Also enable CAPTCHA in Supabase Dashboard → Auth → Bot and Abuse Protection
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
